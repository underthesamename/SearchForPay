EBAY_BROWSE_BASE_URL=
EBAY_OAUTH_BASE_URL=
EBAY_SCOPE=https://api.ebay.com/oauth/api_scope
EBAY_SEARCH_LIMIT=10
EBAY_REQUEST_TIMEOUT_MS=8000

SHOPIFY_STORE_DOMAIN=
